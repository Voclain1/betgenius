// Betgenius — data model
// Postgres (Neon). "Enum-like" fields are kept as plain strings rather than
// real Prisma enums; matching TypeScript union types live in src/lib/enums.ts.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// Role: "USER" | "ADMIN_PENDING" | "ADMIN" | "SUPER_ADMIN"
// SubscriptionTier: "FREE" | "VIP" | "PREMIUM"
// SubscriptionStatus: "PENDING" | "ACTIVE" | "CANCELED" | "EXPIRED"
// PredictionCategory: "FEATURED" | "GENIUS" | "TODAY" | "BANKER" | "VIP" | "PREMIUM"
// PredictionStatus: "DRAFT" | "PENDING_REVIEW" | "APPROVED" | "PUBLISHED" | "ARCHIVED"
// Outcome: "PENDING" | "WON" | "LOST" | "VOID"
// TaskStatus: "OPEN" | "IN_PROGRESS" | "DONE"

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String?
  name           String?
  image          String?
  role           String   @default("USER")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subscription   Subscription?
  predictions    Prediction[]  @relation("PredictionAuthor")
  approvals      Prediction[]  @relation("PredictionApprover")
  assignedTasks  AdminTask[]   @relation("AssignedTo")
  createdTasks   AdminTask[]   @relation("CreatedBy")
  betSlips       BetSlip[]
  aiJobs         AIJob[]
}

model Subscription {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier             String    @default("FREE")
  status           String    @default("PENDING")
  paystackRef      String?
  paystackSubCode  String?
  currentPeriodEnd DateTime?
  approvedById     String?
  approvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model League {
  id        String     @id @default(cuid())
  apiId     Int        @unique
  name      String
  country   String
  logo      String?
  season    Int
  fixtures  Fixture[]
  standings Standing[]
}

model Team {
  id           String     @id @default(cuid())
  apiId        Int        @unique
  name         String
  logo         String?
  country      String?
  homeFixtures Fixture[]  @relation("HomeTeam")
  awayFixtures Fixture[]  @relation("AwayTeam")
  standings    Standing[]
}

model Fixture {
  id           String        @id @default(cuid())
  apiId        Int           @unique
  leagueId     String
  league       League        @relation(fields: [leagueId], references: [id])
  homeTeamId   String
  homeTeam     Team          @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId   String
  awayTeam     Team          @relation("AwayTeam", fields: [awayTeamId], references: [id])
  kickoff      DateTime
  status       String
  homeScore    Int?
  awayScore    Int?
  venue        String?
  predictions  Prediction[]
  betSlipItems BetSlipItem[]
  updatedAt    DateTime      @updatedAt

  @@index([kickoff])
  @@index([leagueId, kickoff])
}

model Standing {
  id           String @id @default(cuid())
  leagueId     String
  league       League @relation(fields: [leagueId], references: [id])
  teamId       String
  team         Team   @relation(fields: [teamId], references: [id])
  rank         Int
  points       Int
  played       Int
  win          Int
  draw         Int
  loss         Int
  goalsFor     Int
  goalsAgainst Int
  form         String?

  @@unique([leagueId, teamId])
}

model Prediction {
  id           String    @id @default(cuid())
  fixtureId    String?
  fixture      Fixture?  @relation(fields: [fixtureId], references: [id])
  category     String // primary category — kept in sync with `categories[0]` for backward compat
  categories   PredictionCategoryLink[]
  leagueApiId  Int? // API-Football league id — see src/lib/leagues.ts for the known list
  leagueName   String?
  homeTeam     String? // free-text match info — not tied to the Fixture ingestion table
  awayTeam     String?
  kickoff      DateTime?
  status       String    @default("DRAFT")
  // market/pick/overUnder below are DISPLAY strings — for every marketType
  // except OTHER they're derived from the structured fields, never typed
  // directly, so auto-settlement (src/lib/markets.ts) has a fixed vocabulary
  // to work from instead of unparseable free text.
  marketType   String    @default("OTHER") // MATCH_WINNER | DOUBLE_CHANCE | OVER_UNDER | BTTS | CORRECT_SCORE | OTHER
  selection    Json? // shape depends on marketType — see src/lib/markets.ts; null for OTHER
  manualSettlementOnly Boolean @default(true) // true for OTHER (and any row predating this field) — never auto-resolved
  market       String
  pick         String
  ouLine       Float? // secondary over/under pick — present on every new prediction regardless of marketType
  ouDirection  String? // OVER | UNDER
  overUnder    String? // display string derived from ouLine/ouDirection, e.g. "Over 2.5 Goals"
  odds         Float?
  confidence   Int
  reasoning    String
  matchPreview String?
  contextComplete Boolean @default(true) // false = AI-generated with zero live data (all football-API context calls came back empty/failed)
  outcome      String    @default("PENDING")
  // A1 settlement: no Fixture-ingestion pipeline exists in this app (Livescores/
  // Fixtures/Standings all hit API-Football live per-request, nothing is written
  // to the Fixture table), so the finished score is looked up per-prediction and
  // stored here directly — consistent with homeTeam/awayTeam already being free
  // text rather than a Fixture relation. See src/app/api/admin/settle/route.ts.
  finalHomeScore Int?
  finalAwayScore Int?
  authorId     String
  author       User      @relation("PredictionAuthor", fields: [authorId], references: [id])
  approvedById String?
  approvedBy   User?     @relation("PredictionApprover", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  publishedAt  DateTime?
  aiJobId      String?
  aiJob        AIJob?    @relation(fields: [aiJobId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([category, status])
  @@index([publishedAt])
}

// A prediction can be cross-posted into multiple category feeds at once
// (e.g. shown free under TODAY and also as a paid VIP exclusive).
model PredictionCategoryLink {
  id           String     @id @default(cuid())
  predictionId String
  prediction   Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  category     String

  @@unique([predictionId, category])
  @@index([category])
}

model AIJob {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  prompt      String
  model       String
  rawOutput   String
  status      String       @default("COMPLETED")
  contextComplete Boolean  @default(true) // false = every football-API context call (team search, form, standings, h2h) came back empty/failed
  createdAt   DateTime     @default(now())
  predictions Prediction[]
}

model AdminTask {
  id           String    @id @default(cuid())
  title        String
  description  String?
  status       String    @default("OPEN")
  dueAt        DateTime?
  createdById  String
  createdBy    User      @relation("CreatedBy", fields: [createdById], references: [id])
  assignedToId String?
  assignedTo   User?     @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model BetSlip {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  name      String        @default("My slip")
  totalOdds Float         @default(1.0)
  stake     Float         @default(0)
  createdAt DateTime      @default(now())
  items     BetSlipItem[]
}

model BetSlipItem {
  id        String  @id @default(cuid())
  betSlipId String
  betSlip   BetSlip @relation(fields: [betSlipId], references: [id], onDelete: Cascade)
  fixtureId String
  fixture   Fixture @relation(fields: [fixtureId], references: [id])
  market    String
  pick      String
  odds      Float
}
